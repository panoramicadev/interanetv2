# ============================================
# PANORAMICA - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores
# 
# LEYENDA:
#   [LOCAL-OK]  = Funciona en entorno local
#   [REPLIT]    = Solo funciona en Replit (requiere mock o alternativa local)
#   [RED-PRIV]  = Requiere acceso a red privada (VPN/túnel)
#   [CONFIG]    = Requiere configuración adicional en servicio externo

# ============================================
# BASE DE DATOS POSTGRESQL [LOCAL-OK]
# ============================================
# Puedes usar la misma DATABASE_URL de Replit Neon desde local
DATABASE_URL=postgresql://usuario:password@host:5432/database?sslmode=require

# ============================================
# SQL SERVER - ETL SOFTLAND [RED-PRIV]
# ============================================
# Si el servidor está en red privada, necesitas VPN o túnel SSH
SQL_SERVER_HOST=ip_o_hostname
SQL_SERVER_PORT=1433
SQL_SERVER_USER=usuario
SQL_SERVER_PASSWORD=password
SQL_SERVER_DATABASE=nombre_db

# ============================================
# SESIONES [LOCAL-OK]
# ============================================
SESSION_SECRET=genera_una_cadena_aleatoria_de_32_caracteres

# ============================================
# GOOGLE OAUTH [CONFIG]
# ============================================
# Debes agregar http://localhost:5000/api/oauth/google/callback 
# como redirect URI autorizado en Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
GMAIL_OAUTH_REDIRECT_URI=http://localhost:5000/api/oauth/google/callback

# ============================================
# META/FACEBOOK ADS [LOCAL-OK]
# ============================================
META_APP_ID=tu_app_id
META_APP_SECRET=tu_app_secret

# ============================================
# APIS EXTERNAS [LOCAL-OK]
# ============================================
SERPAPI_API_KEY=tu_key
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxx
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# OBJECT STORAGE [REPLIT]
# ============================================
# NO FUNCIONA en local - las subidas de archivos fallarán
# Alternativa: implementar almacenamiento local en carpeta uploads/
DEFAULT_OBJECT_STORAGE_BUCKET_ID=repl-default-bucket-xxxx
PUBLIC_OBJECT_SEARCH_PATHS=public
PRIVATE_OBJECT_DIR=.private

# ============================================
# ENTORNO
# ============================================
NODE_ENV=development
